# ===========================================
# HospedaRN — Backend Environment Variables
# ===========================================

# -----------------------------------------------
# APPLICATION
# -----------------------------------------------
NODE_ENV=development
PORT=3000
API_PREFIX=api
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------
# DATABASE (Neon PostgreSQL)
# -----------------------------------------------
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require"

# -----------------------------------------------
# JWT
# -----------------------------------------------
JWT_ACCESS_SECRET=your_very_strong_jwt_access_secret_here_min_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your_very_strong_jwt_refresh_secret_here_min_32_chars
JWT_REFRESH_EXPIRATION=7d

# -----------------------------------------------
# REDIS (local Docker ou Upstash)
# -----------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Para Upstash (produção):
# REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_UPSTASH_HOST:6380

# -----------------------------------------------
# AWS S3
# -----------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=sa-east-1
AWS_S3_BUCKET=hospedarn-uploads
AWS_S3_BASE_URL=https://hospedarn-uploads.s3.sa-east-1.amazonaws.com

# -----------------------------------------------
# EMAIL (Nodemailer)
# -----------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="HospedaRN <noreply@hospedarn.com.br>"

# -----------------------------------------------
# WHATSAPP (opcional)
# -----------------------------------------------
# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Evolution API (alternativo)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# -----------------------------------------------
# RATE LIMIT
# -----------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# -----------------------------------------------
# SWAGGER
# -----------------------------------------------
SWAGGER_ENABLED=true
SWAGGER_TITLE=HospedaRN API
SWAGGER_DESCRIPTION=API do sistema de hospedagens do Rio Grande do Norte
SWAGGER_VERSION=1.0
SWAGGER_PATH=api/docs
