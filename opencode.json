{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },

    "supabase": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=busezzayowpvobjthqfn"
    },

    "railway": {
      "enabled": true,
      "type": "local",
      "command": "railway",
      "args": ["mcp"]
    },

    "Neon": {
      "enabled": true,
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.neon.tech/sse"
      ]
    }
  }
}